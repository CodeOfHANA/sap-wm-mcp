@EndUserText.label: 'WM MCP Service Definition'
define service ZSD_WMMcpService {
  expose ZC_WMStoragBin           as WMStorageBin;
  expose ZC_WMWarehouseStock      as WMWarehouseStock;
  expose ZR_WMTransferOrder       as WMTransferOrder;
  expose ZR_WMTransferOrderItem   as WMTransferOrderItem;
  expose ZR_WMTransferRequirement as WMTransferRequirement;
  expose ZR_WMIMStock             as WMIMStock;
  expose ZR_WMCycleCountBin       as WMCycleCountBin;
}
